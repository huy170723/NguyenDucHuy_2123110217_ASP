@{
    Layout = null;
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hồ sơ</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
<nav class="navbar navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="/">YAME CLONE</a>
    <div>
      <a class="btn btn-outline-light btn-sm" href="/">Trang chủ</a>
    </div>
  </div>
</nav>

<div class="container py-4">
    <h3>Hồ sơ người dùng</h3>
    <div id="profileArea">Đang tải...</div>
</div>

<script>
(async function(){
    const user = JSON.parse(localStorage.getItem('user')||'null');
    if(!user){ document.getElementById('profileArea').innerHTML = '<div class="text-danger">Vui lòng đăng nhập để xem hồ sơ</div>'; return; }
    try{
        const res = await fetch('/api/profile/' + user.userId);
        if(!res.ok) throw new Error('Không tải được');
        const data = await res.json();
        var html = '<h4>' + (data.user.name || '') + ' (@@' + (data.user.username || '') + ')</h4>' +
                   '<p>Email: ' + (data.user.email || '') + '</p><hr/><h5>Lịch sử mua hàng</h5>';
        if(!data.orders || !data.orders.length) html += '<div>Chưa có đơn hàng</div>';
        else{
            data.orders.forEach(function(o){
                html += '<div class="card mb-2"><div class="card-body"><strong>Order #' + o.orderId + '</strong> - ' + (o.status || '') + ' - Tổng: ' + Number(o.total).toLocaleString('vi-VN') + ' VNĐ';
                html += '<ul>';
                o.items.forEach(function(i){ html += '<li>' + (i.name || '') + ' x' + i.qty + ' - ' + Number(i.price).toLocaleString('vi-VN') + ' VNĐ</li>'; });
                html += '</ul></div></div>';
            });
        }
        document.getElementById('profileArea').innerHTML = html;
    }catch(e){ console.error(e); document.getElementById('profileArea').innerHTML = '<div class="text-danger">Lỗi khi tải hồ sơ</div>'; }
})();
</script>
</body>
</html>