@model NguyenDucHuy_2123110217_ASP.Controllers.CatalogController.ProductListViewModel

@{
    Layout = null; // using static layout, index.html is used for home; but render simple view
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Catalog</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container py-4">
    <div class="row">
        <div class="col-md-3">
            <h5>Danh mục</h5>
            <ul class="list-group">
                <li class="list-group-item @(Model.SelectedCategoryId==0?"active":"")"><a href="/Catalog">Tất cả</a></li>
                @foreach(var c in Model.Categories){
                    <li class="list-group-item @(Model.SelectedCategoryId==c.CategoryId?"active":"")">
                        <a href="/Catalog?categoryId=@c.CategoryId">@c.Name</a>
                    </li>
                }
            </ul>
        </div>
        <div class="col-md-9">
            <form method="get" class="mb-3">
                <div class="input-group">
                    <input name="q" value="@Model.SearchQuery" class="form-control" placeholder="Tìm tên sản phẩm" />
                    <button class="btn btn-dark">Tìm</button>
                </div>
            </form>

            <div class="row">
                @if(!Model.Products.Any()){
                    <div class="col-12 text-muted">Không có sản phẩm</div>
                } else {
                    foreach(var p in Model.Products){
                        <div class="col-6 col-md-4 mb-3">
                            <div class="card p-2">
                                <img src="@(p.ImageUrl ?? "https://via.placeholder.com/300x400")" class="img-fluid" />
                                <div class="card-body">
                                    <strong>@p.Name</strong>
                                    <div class="text-danger">@((p.ProductVariants?.FirstOrDefault()?.Price ?? p.Price).ToString("N0")) VNĐ</div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <nav>
                <ul class="pagination">
                    @for(int i=1;i<=Model.TotalPages;i++){
                        <li class="page-item @(i==Model.Page?"active":"")"><a class="page-link" href="/Catalog?page=@i&categoryId=@Model.SelectedCategoryId&q=@Model.SearchQuery">@i</a></li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>
</body>
</html>